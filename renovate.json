{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/lint\\.yaml$/"],
      "matchStrings": [
        "SHFMT_VERSION:\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mvdan/sh"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/lint\\.yaml$/"],
      "matchStrings": [
        "DOCKERFMT_VERSION:\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "reteps/dockerfmt"
    }
  ]
}
